#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)/ows"

echo "Running cargo fmt..."
cargo fmt --all

echo "Running cargo clippy..."
cargo clippy --workspace --fix --allow-dirty --allow-staged -- -D warnings

# Re-stage any files modified by fmt/clippy
cd "$(git rev-parse --show-toplevel)"
git diff --name-only | while IFS= read -r f; do
  git check-ignore -q "$f" || git add "$f"
done

echo "Running cargo build..."
cd "$(git rev-parse --show-toplevel)/ows"
cargo build --workspace

echo "Pre-commit checks passed."
