{
  "name": "@open-wallet-standard/web",
  "version": "1.3.2",
  "description": "Browser WASM bindings for the Open Wallet Standard",
  "type": "module",
  "main": "src/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    },
    "./stores/indexeddb": {
      "types": "./index.d.ts",
      "import": "./src/stores/indexeddb.js"
    },
    "./stores/lightning-fs": {
      "types": "./index.d.ts",
      "import": "./src/stores/lightning-fs.js"
    },
    "./stores/memory": {
      "types": "./index.d.ts",
      "import": "./src/stores/memory.js"
    }
  },
  "files": [
    "README.md",
    "index.d.ts",
    "pkg",
    "src"
  ],
  "scripts": {
    "build": "wasm-pack build --target bundler --out-dir pkg",
    "build:dev": "wasm-pack build --dev --target bundler --out-dir pkg --features fast-kdf",
    "check": "cargo check --features fast-kdf",
    "test": "node --test __test__/*.spec.mjs"
  },
  "license": "MIT"
}
